{
  "name": "gial-dsr",
  "version": "1.0.0",
  "private": true,
  "description": "GIAL Daily Service Reporting System",
  "scripts": {
    "dev:web": "cd packages/web && npm run dev",
    "dev:mobile": "cd packages/mobile && npx expo start",
    "build:web": "cd packages/web && npm run build",
    "build:mobile": "cd packages/mobile && npx expo export",
    "typecheck": "cd packages/web && npx tsc --noEmit && cd ../mobile && npx tsc --noEmit",
    "lint": "echo 'lint not configured'",
    "test": "echo 'tests not configured'"
  }
}
